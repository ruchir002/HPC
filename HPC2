#include<iostream>
#include<omp.h>
#include<time.h>
using namespace std;
// ---------- Parallel Bubble Sort ----------
void bubbleSort(int a[], int n)
{
    for(int i = 0; i < n-1; i++)
    {
        #pragma omp parallel for
        for(int j = 0; j < n-i-1; j++)
        {
            if(a[j] > a[j+1])
            {
                int temp = a[j];
                a[j] = a[j+1];
                a[j+1] = temp;
            }
        }
    }
}
// ---------- Merge Function ----------
void merge(int a[], int low, int mid, int high)
{
    int temp[100];
    int i = low, j = mid+1, k = low;
    while(i <= mid && j <= high)
    {
        if(a[i] < a[j])
            temp[k++] = a[i++];
        else
            temp[k++] = a[j++];
    }
    while(i <= mid)
        temp[k++] = a[i++];
    while(j <= high)
        temp[k++] = a[j++];
    for(i = low; i <= high; i++)
        a[i] = temp[i];
}
// ---------- Parallel Merge Sort ----------
void mergeSort(int a[], int low, int high)
{
    if(low < high)
    {
        int mid = (low + high) / 2;
        #pragma omp parallel sections
        {
            #pragma omp section
            mergeSort(a, low, mid);
            #pragma omp section
            mergeSort(a, mid+1, high);
        }
        merge(a, low, mid, high);
    }
}
// ---------- Print ----------
void printArray(int a[], int n)
{
    for(int i = 0; i < n; i++)
        cout << a[i] << " ";
}
// ---------- Main ----------
int main()
{
    int n;
    cout << "Enter number of elements: ";
    cin >> n;
    int a[100], b[100];
    cout << "Enter elements:\n";
    for(int i = 0; i < n; i++)
    {
        cin >> a[i];
        b[i] = a[i];
    }
    clock_t start, end;
    // Bubble Sort
    start = clock();
    bubbleSort(a, n);
    end = clock();
    cout << "\nBubble Sort Output:\n";
    printArray(a, n);
    cout << "\nTime = "
     << (double)(end - start) * 1000 / CLOCKS_PER_SEC
     << " ms\n";
    // Merge Sort
    start = clock();
    mergeSort(b, 0, n-1);
    end = clock();
    cout << "\nMerge Sort Output:\n";
    printArray(b, n);
    cout << "\nTime = "
     << (double)(end - start) * 1000 / CLOCKS_PER_SEC
     << " ms\n";
    return 0;
}
